# Required — Telegram bot from @BotFather
TELEGRAM_BOT_TOKEN=

# DATABASE_URL=postgres://meetings:meetings@localhost:5432/meetings?sslmode=disable
DATABASE_URL=postgres://meetings:meetings@localhost:5432/meetings?sslmode=disable

# Optional (default :8080)
HTTP_ADDR=:8080

# Optional — Uber Fx startup trace to stdout: FX_LOG=debug (or true/1/yes), or FX_DEBUG=1, or LOG_LEVEL=debug
# FX_LOG=debug

# Optional — background workers processing transcribe/chat jobs
WORKER_POOL=3

# Required — GigaChat OAuth (Studio / developer portal)
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

# Optional 
# GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
# GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions
# GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Required — SaluteSpeech / SmartSpeech OAuth
SALUTESPEECH_CLIENT_ID=
SALUTESPEECH_CLIENT_SECRET=

# Optional 
# SALUTESPEECH_REST_URL=https://smartspeech.sber.ru/rest/v1
# SALUTESPEECH_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
# SALUTESPEECH_SCOPE=SALUTE_SPEECH_PERS
